# LLM provider: claude | openai | ollama | groq | custom (default: claude)
STORAGE_EXPERT_PROVIDER=claude

# API keys — set the one(s) you need
ANTHROPIC_API_KEY=your-anthropic-key-here
OPENAI_API_KEY=your-openai-key-here
GROQ_API_KEY=your-groq-api-key-here

# Custom / router API (OpenAI-compatible endpoint)
# Use with: STORAGE_EXPERT_PROVIDER=custom
CUSTOM_API_URL=https://your-router-url/v1
CUSTOM_API_KEY=your-router-api-key-here
CUSTOM_API_MODEL=your-model-name-here

# Embeddings backend: huggingface | openai | ollama (default: huggingface)
# huggingface: runs locally, no API key needed (downloads ~80MB model on first use)
# openai: requires OPENAI_API_KEY, higher quality
# ollama: requires Ollama running locally with nomic-embed-text pulled
STORAGE_EXPERT_EMBEDDINGS=huggingface

# MCP integration — optional, enables live tool calling alongside RAG
# Create mcp_servers.json in the project root to configure one or more MCP servers.
# See mcp_servers.example.json for the format. Requires: pip install -e '.[mcp]'
