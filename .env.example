# Web auth — generate a strong random value before deploying
SECRET_KEY=change-me-in-production

# LLM — any OpenAI-compatible endpoint
API_URL=https://api.openai.com/v1
API_KEY=your-api-key-here
LLM_MODEL=gpt-4o

# Embeddings — defaults to the same API_URL/API_KEY as the LLM
# Override if your embedding endpoint differs from the LLM endpoint
# EMBED_API_URL=https://api.openai.com/v1
# EMBED_API_KEY=your-embed-api-key-here
EMBED_MODEL=text-embedding-3-small

# RAG / PDF knowledge base — set to false to run as a pure LLM or MCP-only assistant
# When disabled: PDF upload and ChromaDB are skipped; the sidebar Knowledge Base panel is hidden.
# MCP tools continue to work normally when RAG is disabled.
STORAGE_EXPERT_RAG_ENABLED=true

# MCP integration — optional, enables live tool calling alongside RAG
# Create mcp_servers.json in the project root to configure one or more MCP servers.
# See mcp_servers.example.json for the format. Requires: pip install -e '.[mcp]'

# NOTE: If you switch EMBED_MODEL after ingesting documents, you must wipe and
# re-ingest your ChromaDB data — embedding dimensions differ between models:
#   make reset && make reingest
